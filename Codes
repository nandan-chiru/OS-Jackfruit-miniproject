#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <signal.h>
#include <sys/socket.h>
#include <sys/un.h>
#include <sys/wait.h>
#include <fcntl.h>

#define SOCKET_PATH "/tmp/supervisor.sock"
#define MAX_CONTAINERS 100

typedef struct {
    char name[50];
    pid_t pid;
    int running;
} Container;

Container containers[MAX_CONTAINERS];
int count = 0;
int server_fd;

// Utility
int find_container(const char *name) {
    for (int i = 0; i < count; i++) {
        if (strcmp(containers[i].name, name) == 0)
            return i;
    }
    return -1;
}

// SIGCHLD
void sigchld_handler(int sig) {
    int status;
    pid_t pid;
    while ((pid = waitpid(-1, &status, WNOHANG)) > 0) {
        for (int i = 0; i < count; i++) {
            if (containers[i].pid == pid) {
                containers[i].running = 0;
                break;
            }
        }
    }
}

// Shutdown
void cleanup(int sig) {
    printf("\n[Supervisor] Shutting down...\n");
    for (int i = 0; i < count; i++) {
        if (containers[i].running) {
            kill(containers[i].pid, SIGTERM);
        }
    }
    close(server_fd);
    unlink(SOCKET_PATH);
    exit(0);
}

// Start
void handle_start(int client, char *name, char *cmd) {
    pid_t pid = fork();
    if (pid == 0) {
        // Child -> redirect logs
        char logfile[100];
        sprintf(logfile, "%s.log", name);
        int fd = open(logfile, O_CREAT | O_WRONLY | O_APPEND, 0644);
        dup2(fd, STDOUT_FILENO);
        dup2(fd, STDERR_FILENO);
        execl("/bin/sh", "sh", "-c", cmd, NULL);
        exit(1);
    }
    strcpy(containers[count].name, name);
    containers[count].pid = pid;
    containers[count].running = 1;
    count++;
    write(client, "STARTED\n", 8);
}

// Run (foreground)
void handle_run(int client, char *name, char *cmd) {
    pid_t pid = fork();
    if (pid == 0) {
        execl("/bin/sh", "sh", "-c", cmd, NULL);
        exit(1);
    }
    waitpid(pid, NULL, 0);
    write(client, "FINISHED\n", 9);
}

// PS
void handle_ps(int client) {
    char buffer[1024] = "";
    for (int i = 0; i < count; i++) {
        char line[128];
        sprintf(line, "%s | PID=%d | %s\n",
            containers[i].name,
            containers[i].pid,
            containers[i].running ? "RUNNING" : "EXITED");
        strcat(buffer, line);
    }
    write(client, buffer, strlen(buffer));
}

// STOP
void handle_stop(int client, char *name) {
    int idx = find_container(name);
    if (idx == -1) {
        write(client, "NOT FOUND\n", 10);
        return;
    }
    pid_t pid = containers[idx].pid;
    kill(pid, SIGTERM);
    sleep(1);
    if (kill(pid, 0) == 0) {
        kill(pid, SIGKILL);
        write(client, "FORCE KILLED\n", 13);
    } else {
        write(client, "GRACEFUL STOP\n", 14);
    }
}

// LOGS
void handle_logs(int client, char *name) {
    char filename[100];
    sprintf(filename, "%s.log", name);
    FILE *f = fopen(filename, "r");
    if (!f) {
        write(client, "NO LOGS\n", 8);
        return;
    }
    char buffer[256];
    while (fgets(buffer, sizeof(buffer), f)) {
        write(client, buffer, strlen(buffer));
    }
    fclose(f);
}

// Command Dispatcher
void process_command(int client, char *cmd) {
    char *token = strtok(cmd, " \n");
    if (!token) return;
    if (strcmp(token, "start") == 0) {
        char *name = strtok(NULL, " ");
        char *rest = strtok(NULL, "\n");
        handle_start(client, name, rest);
    }
    else if (strcmp(token, "run") == 0) {
        char *name = strtok(NULL, " ");
        char *rest = strtok(NULL, "\n");
        handle_run(client, name, rest);
    }
    else if (strcmp(token, "ps") == 0) {
        handle_ps(client);
    }
    else if (strcmp(token, "stop") == 0) {
        char *name = strtok(NULL, " ");
        handle_stop(client, name);
    }
    else if (strcmp(token, "logs") == 0) {
        char *name = strtok(NULL, " ");
        handle_logs(client, name);
    }
    else {
        write(client, "UNKNOWN COMMAND\n", 16);
    }
}

// Main
int main() {
    struct sockaddr_un addr;
    signal(SIGCHLD, sigchld_handler);
    signal(SIGINT, cleanup);
    signal(SIGTERM, cleanup);
    server_fd = socket(AF_UNIX, SOCK_STREAM, 0);
    unlink(SOCKET_PATH);
    memset(&addr, 0, sizeof(addr));
    addr.sun_family = AF_UNIX;
    strcpy(addr.sun_path, SOCKET_PATH);
    bind(server_fd, (struct sockaddr*)&addr, sizeof(addr));
    listen(server_fd, 5);
    printf("[Supervisor] Running...\n");
    while (1) {
        int client = accept(server_fd, NULL, NULL);
        char buffer[1024] = {0};
        read(client, buffer, sizeof(buffer));
        process_command(client, buffer);
        close(client);
    }
    return 0;
}
